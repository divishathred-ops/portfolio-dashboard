                <bin default-name='true' value='&quot;Phase E - Deployment&quot;'>
                  <value>&quot;Phase E - Deployment&quot;</value>
                </bin>
              </calculation>
            </column>
            <column aggregation='CountD' datatype='string' name='[Phase]' role='dimension' type='nominal' />
            <column caption='Planned Cost' datatype='integer' name='[Planned_Cost]' role='measure' type='quantitative' />
            <column datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column-instance column='[Date]' derivation='Month-Trunc' name='[tmn:Date:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_1105070800625205248]' derivation='User' name='[usr:Calculation_1105070800625205248:qk]' pivot='key' type='quantitative' />
