      <aliases enabled='yes' />
      <column caption='Actual Cost' datatype='integer' name='[Actual_Cost]' role='measure' type='quantitative' />
      <column caption='Actual Deliverables' datatype='integer' name='[Actual_Deliverables]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Actual_Duration]' role='measure' type='quantitative' />
      <column caption='Overall Cost Variance' datatype='real' name='[Calculation_1105070800625205248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Actual_Cost]) - SUM([Planned_Cost])) / SUM([Planned_Cost])' />
      </column>
      <column caption='Variance Color Flag' datatype='string' name='[Calculation_1407656401450573824]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Cost_Variance]) &gt; 65000 THEN &quot;Out of Bounds&quot;&#13;&#10;ELSEIF SUM([Cost_Variance]) &lt; -35000 THEN &quot;ON TRACK&quot;&#13;&#10;ELSE &quot;AT RISK&quot;&#13;&#10;END' />
      </column>
      <column caption='COUNTRIS_TOP10_BOTTOM_10' datatype='boolean' name='[Calculation_1407656401491382273]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Cost_Variance]), &apos;desc&apos;) &lt;= 10 &#13;&#10;OR &#13;&#10;RANK(SUM([Cost_Variance]), &apos;asc&apos;) &lt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Success Rate' datatype='real' name='[Calculation_435160356359516160]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Actual_Deliverables]) / SUM([Planned_Delivrable])' />
      </column>
      <column caption='Cost Variance' datatype='integer' name='[Cost_Variance]' role='measure' type='quantitative' />
      <column caption='Cost Variance Pct' datatype='real' name='[Cost_Variance_Pct]' role='measure' type='quantitative' />
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
